# Supabase (Service Role — yalnızca güvenli ortamda, asla frontend'e koymayın)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Overpass API (varsayılan: overpass-api.de)
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Upsert batch boyutu
BATCH_SIZE=200

# true ise veritabanına yazmaz, yalnızca log üretir
DRY_RUN=false
